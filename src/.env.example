# Telegram
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
PAYMENT_TOKEN=YOUR_TELEGRAM_PAYMENTS_TOKEN_HERE

# Comma-separated list of Telegram user IDs (admins)
ADMINS=123456789,987654321

# 3X-UI / XUI API
# Base URL WITHOUT path, e.g. http://127.0.0.1:2053
XUI_API_URL=http://<IP>:<PORT>
XUI_HOST=example.com
# If panel is mounted under /<CUSTOM_PATH>/... set this to CUSTOM_PATH (without leading/trailing slashes).
# Example: for http://<IP>:<PORT>/<CUSTOM_PATH>/login -> XUI_BASE_PATH=<CUSTOM_PATH>
XUI_BASE_PATH=<CUSTOM_PATH>
XUI_SERVER_NAME=example.com
XUI_USERNAME=YOUR_XUI_USERNAME
XUI_PASSWORD=YOUR_XUI_PASSWORD
INBOUND_ID=1

# Reality parameters for VLESS URL
REALITY_PUBLIC_KEY=YOUR_REALITY_PUBLIC_KEY
REALITY_FINGERPRINT=YOUR_REALITY_FINGERPRINT
REALITY_SNI=YOUR_REALITY_SNI
REALITY_SHORT_ID=YOUR_REALITY_SHORT_ID
REALITY_SPIDER_X=YOUR_REALITY_SPIDER_X

# Subscription policy
TRIAL_DAYS=3
MAX_VLESS_KEYS=5

# Telegram Payments: суммы в минорных единицах (RUB — копейки: 300 ₽ = 30000)
# Тарифы: 300 / 800 / 1500 / 2700 рублей
PRICE_EXTRA_VLESS_KEY=15000
PRICE_1_MONTH=30000
PRICE_3_MONTHS=80000
PRICE_6_MONTHS=150000
PRICE_12_MONTHS=270000
CURRENCY=RUB

